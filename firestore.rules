rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && (
        request.auth.token.admin == true
        || (
          exists(/databases/$(database)/documents/members/$(request.auth.uid))
          && get(/databases/$(database)/documents/members/$(request.auth.uid)).data.role == 'admin'
        )
      );
    }

    function isMemberSelf(memberId) {
      return signedIn() && (
        memberId == request.auth.uid
        || (
          exists(/databases/$(database)/documents/members/$(memberId))
          && get(/databases/$(database)/documents/members/$(memberId)).data.authUid == request.auth.uid
        )
      );
    }

    match /familyLogins/{login} {
      allow get: if true;
      allow list: if false;
      allow create, update, delete: if isAdmin();
    }

    match /members/{memberId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
      allow update: if signedIn()
        && (
          isMemberSelf(memberId)
          || resource.data.authUid == null
          || resource.data.authUid == ''
        )
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'authUid',
          'updatedAt',
          'fcmToken',
          'photoUrl',
          'photoZoom',
          'photoOffsetX',
          'photoOffsetY',
          'themeMode',
          'soundEnabled',
          'vibrationEnabled'
        ])
        && (
          !request.resource.data.diff(resource.data).changedKeys().hasAny(['authUid'])
          || request.resource.data.authUid == request.auth.uid
        );
    }

    match /tasks/{taskId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
      allow update: if signedIn()
        && isMemberSelf(resource.data.assignedToId)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'completedAt', 'completedBy', 'updatedAt']);
      allow update: if signedIn()
        && resource.data.assignedToId == ''
        && resource.data.status == 'pending'
        && isMemberSelf(request.resource.data.assignedToId)
        && request.resource.data.status == 'inProgress'
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['assignedToId', 'status', 'updatedAt']);
      allow update: if signedIn()
        && resource.data.assignedToId == ''
        && (resource.data.status == 'pending' || resource.data.status == 'inProgress')
        && resource.data.completedBy.size() == 0
        && resource.data.approvedBy.size() == 0
        && request.resource.data.participantIds.size() == resource.data.participantIds.size() + 1
        && request.resource.data.participantIds.hasAll(resource.data.participantIds)
        && request.resource.data.completedBy == resource.data.completedBy
        && request.resource.data.approvedBy == resource.data.approvedBy
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['participantIds', 'status', 'updatedAt']);
      allow update: if signedIn()
        && resource.data.assignedToId == ''
        && resource.data.status != 'done'
        && request.resource.data.participantIds == resource.data.participantIds
        && request.resource.data.completedBy.size() == resource.data.completedBy.size() + 1
        && request.resource.data.completedBy.hasAll(resource.data.completedBy)
        && request.resource.data.completedBy.hasOnly(resource.data.participantIds)
        && request.resource.data.approvedBy == resource.data.approvedBy
        && request.resource.data.status == 'awaitingApproval'
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['completedBy', 'status', 'updatedAt']);
    }

    match /announcements/{announcementId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /activities/{activityId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
      allow update: if signedIn()
        && isMemberSelf(resource.data.assignedToId)
        && request.resource.data.assignedToId == resource.data.assignedToId
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'status',
          'acceptedAt',
          'onWayAt',
          'completedAt',
          'missedAt',
          'updatedAt'
        ]);
    }

    match /notifications/{notificationId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
      allow update: if signedIn()
        && isMemberSelf(resource.data.assignedToId)
        && request.resource.data.assignedToId == resource.data.assignedToId
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['acceptedAt', 'updatedAt']);
    }

    match /settings/{settingId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /history/{historyId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if false;
    }
  }
}
